#!/bin/sh

commit_msg=$(head -1 "$1")

pattern="^(feat|fix|docs|refactor|test|chore|style|perf|ci|build): .+"

if ! echo "$commit_msg" | grep -Eq "$pattern"; then
  echo ""
  echo "Commit rejeitado! A mensagem nao segue o padrao de Conventional Commits."
  echo ""
  echo "Formato esperado:"
  echo "  <tipo>: descricao curta"
  echo ""
  echo "Tipos permitidos: feat, fix, docs, refactor, test, chore, style, perf, ci, build"
  echo ""
  echo "Exemplos:"
  echo "  feat: adicionar comando /start ao bot"
  echo "  fix: corrigir timeout na conexao com a API do Telegram"
  echo "  docs: adicionar guia de configuracao do bot"
  echo ""
  exit 1
fi
